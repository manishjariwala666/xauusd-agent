# Copy this file to .env and replace every placeholder.
# Never commit the real .env file.

DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@HOST:5432/DATABASE
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHANNEL_OR_CHAT_ID

# Keep the complete service-account document on one line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"YOUR_KEY_ID","private_key":"YOUR_PRIVATE_KEY","client_email":"YOUR_SERVICE_ACCOUNT_EMAIL","client_id":"YOUR_CLIENT_ID","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_SHEET_NAME=xauusd_automation
GOOGLE_WORKSHEET_NAME=Sheet1

# Optional: exact XAU/USD spot price. Without it, GC=F is used as fallback.
GOLDAPI_KEY=
XAUUSD_SYMBOL=GC=F
SIGNAL_POLL_SECONDS=60

# Required by every application process.
# Supabase Dashboard > Project Settings > Database > Connection string.
DATABASE_URL=
# Supabase Dashboard > Project Settings > API.
SUPABASE_URL=
SUPABASE_KEY=
# Generate a private random value of at least 32 characters.
JWT_SECRET=

# Authentication and email delivery.
JWT_ISSUER=ai-market-analytics-pro
JWT_TTL_MINUTES=60
APP_BASE_URL=
# Railway-generated public domain for the FastAPI service.
BACKEND_BASE_URL=
# Optional overrides when website and API live on different public domains.
PUBLIC_WEBSITE_URL=
PUBLIC_SITE_URL=
STREAMLIT_PUBLIC_URL=
PUBLIC_API_URL=
# Set true while moving to a new domain/staging site to stop crawler indexing.
BLOCK_SEARCH_INDEXING=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
SMTP_USE_TLS=true

# Telegram BotFather, Telegram channel/chat, and a private webhook secret.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
MASTER_AI_TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=
TELEGRAM_ADMIN_USER_IDS=
MASTER_AI_ALLOW_NATURAL_COMMANDS=false
TELEGRAM_INVITE_URL=
PROFIT_PROOF_TELEGRAM_URL=

# Meta for Developers > WhatsApp Business Cloud API.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
SUPPORT_WHATSAPP_URL=

# Google Cloud service account and the shared Google Sheet.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_NAME=xauusd_automation
GOOGLE_WORKSHEET_NAME=Sheet1

# Market data. GOLDAPI_KEY is optional; Yahoo is the fallback provider.
GOLDAPI_KEY=
XAUUSD_SYMBOL=GC=F
SIGNAL_POLL_SECONDS=60

# AI providers. Gemini handles text by default; OpenAI is required for images.
AI_PROVIDER=GEMINI
GEMINI_API_KEY=
OPENAI_API_KEY=
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gpt-image-1

# Subscription, branding, and support.
USDT_WALLET_ADDRESS=
USDT_NETWORK=
SUBSCRIPTION_PRICE_USDT=
SUPPORT_EMAIL=
BRAND_NAME=AI Market Analytics Pro

# Worker behavior.
HUMAN_TAKEOVER_MINUTES=30
WORKER_POLL_SECONDS=5
